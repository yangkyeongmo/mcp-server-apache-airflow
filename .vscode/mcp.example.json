{
  "_readme": [
    "VSCode GitHub Copilot MCP config - place at .vscode/mcp.json",
    "Run: ./setup-mcp.sh rest (auto-replaces $PROJECT_DIR)",
    "Or copy this file to .vscode/mcp.json and replace $PROJECT_DIR with actual path",
    "Note: Uses 'servers' key (not 'mcpServers') for VSCode Copilot format"
  ],
  "servers": {
    "airflow-sso": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "$PROJECT_DIR",
        "--extra",
        "sso",
        "mcp-server-apache-airflow"
      ],
      "env": {
        "AIRFLOW_HOST": "https://pidgey.ready-internal.net",
        "AIRFLOW_SSO_AUTH": "true",
        "AIRFLOW_VERIFY": "false",
        "AIRFLOW_STATE_DIR": "$PROJECT_DIR/.airflow_state",
        "READ_ONLY": "true"
      }
    }
  }
}
